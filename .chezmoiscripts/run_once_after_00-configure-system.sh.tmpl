#!{{ lookPath "sh" }}

# templates
{{ template "helpers" . }}

bot "run_once_after_00-configure-system.sh"
running "checking system platform"
{{ if (eq .chezmoi.os "linux") }}
	ok "linux platform"
{{ else if (eq .chezmoi.os "darwin") }}
	ok "macos platform"
	{{ template "sudo" . }}
    {{ template "macos" . }}
{{ else }}
    fail "platform not supported"
	exit 0
{{ end }}